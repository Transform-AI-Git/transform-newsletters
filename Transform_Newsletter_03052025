                        <!-- Feature 2: Artifact Templates -->
                        <p style="margin-bottom: 1em; margin: 0 0 5px 0; color: #FFFFFF; font-size: 17px; line-height: 1.6; font-family: 'Satoshi', 'Montserrat', sans-serif;"><strong style="color: #A0DDFD; border-left: 3px solid #A0DDFD; padding-left: 8px;">Artifact Templates</strong></p>
                        
